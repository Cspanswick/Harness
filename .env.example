# Supabase — Project Settings → API
# Copy to .env.local and fill in. Never commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Shared "access code" sign-in for /enter (optional — no email required).
# APP_ACCESS_CODE: the code users type on the /enter page.
# HARNESS_ACCOUNT_*: a confirmed Supabase user (create one with a password in
# the dashboard). The /enter page signs into this shared account server-side;
# these never reach the browser. Leave blank to disable access-code sign-in.
APP_ACCESS_CODE=
HARNESS_ACCOUNT_EMAIL=
HARNESS_ACCOUNT_PASSWORD=
